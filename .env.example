# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-scripts-only
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_PROJECT_REF=your-project-ref

# Worker / redirect tracking
WORKER_ENDPOINT=https://your-worker.yourdomain.com/r
WORKER_DEPLOY_COMMAND=echo "Configure worker deployment command"
HEALTH_CHECK_URL=https://your-worker.yourdomain.com/health

# ManyChat / automation
MANYCHAT_WEBHOOK_URL=https://your-manychat-webhook-url
TRACKING_REDIRECT_DOMAIN=https://your-worker.yourdomain.com

# Expo / app deployment
EXPO_TOKEN=your-expo-token
EAS_PROJECT_ID=your-eas-project-id

# App runtime
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_WORKER_ENDPOINT=https://your-worker.yourdomain.com/r
